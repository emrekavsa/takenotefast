{
  "expo": {
    "name": "AcilPing",
    "slug": "acil-ping",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.takenotefast.acilping",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSUserNotificationsUsageDescription": "Size acil uyarıları anında iletebilmek için bildirim iznine ihtiyacımız var.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.takenotefast.acilping",
      "useNextNotificationsApi": true,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#dc2626"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a6b1f6c8-da0a-4363-85db-f5e3d9a97f46"
      }
    },
    "owner": "mendak"
  }
}
